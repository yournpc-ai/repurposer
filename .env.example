# Minimax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=minimax-m3
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Auth / Email
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=Repurposer <repurposer@yournpc.ai>
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_EXPIRE_DAYS=30
AUTH_ALLOW_DEFAULT_USER=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repurposer

# Storage
# All user uploads and rendered outputs are stored under this directory,
# scoped by user id: assets/{user_id}/uploads/... and assets/{user_id}/outputs/...
ASSET_DIR=./assets

# Backend
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
