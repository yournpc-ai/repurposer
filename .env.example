# Minimax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=minimax-m3
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Auth / Email
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=Repurposer <repurposer@yournpc.ai>
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_EXPIRE_DAYS=30
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repurposer

# Storage (S3-compatible object storage, e.g. Volcengine TOS)
# All user uploads and rendered outputs are stored as object keys.
# Reads are public; uploads use presigned PUT URLs generated by the backend.
S3_ENDPOINT_URL=https://tos-s3-ap-southeast-1.volces.com
S3_BUCKET_NAME=repurposer
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_REGION=ap-southeast-1
S3_PUBLIC_URL=https://repurposer.tos-ap-southeast-1.volces.com
S3_PRESIGN_UPLOAD_TTL=3600

# Backend
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
